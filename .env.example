# ─────────────────────────────────────────────────────────────────────────────
# BPA Admin Panel — Environment Variables
# Copy this file to .env.local and fill in real values before running locally.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Next.js / NextAuth ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change_me_min_32_chars_random_string_here

# ─── Backend API ────────────────────────────────────────────────────
# Server-side URL (used by NextAuth authorize + API proxy routes)
BACKEND_API_URL=http://localhost:4000/api/v1

# Client-side URL (used by browser-side fetch calls)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Google Tag Manager ─────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=

# ─── Google Analytics 4 ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ─── Meta (Facebook) Pixel ──────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Google Search Console verification ──────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Meta / Facebook domain verification ─────────────────────────────
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=

# ─── Google Ads conversion tracking ──────────────────────────────────
NEXT_PUBLIC_GOOGLE_ADS_ID=

# ─── Production notes ───────────────────────────────────────────────
# For production set these in your VPS environment, DO NOT commit .env.production:
#   NEXTAUTH_URL=https://admin.bpa.org.bd
#   NEXTAUTH_SECRET=$(openssl rand -base64 32)
#   BACKEND_API_URL=https://api.bpa.org.bd/api/v1
#   NEXT_PUBLIC_API_BASE_URL=https://api.bpa.org.bd
#   NEXT_PUBLIC_API_URL=https://api.bpa.org.bd
#   NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
#   NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
#   NEXT_PUBLIC_META_PIXEL_ID=1234567890123456
