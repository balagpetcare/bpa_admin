# BPA Admin Panel — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.

# Backend API base URL (no trailing slash, no /api/v1)
BACKEND_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_to_a_long_random_string_in_production

# Media / file storage
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:4000
# Uncomment for MinIO / S3 direct URLs:
# NEXT_PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:9000/bpa-pets
