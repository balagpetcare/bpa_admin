# ─────────────────────────────────────────────────────────────────────────────
# BPA Admin Panel — Production Environment Variables
# Copy to .env.local on the production server. Never commit the filled-in file.
#
# Generate NEXTAUTH_SECRET:
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://admin.bangladeshpetassociation.com
# Min 32 chars — use: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Backend API ─────────────────────────────────────────────────────────────
# Server-side URL used by NextAuth authorize callback and API proxy routes.
BACKEND_API_URL=https://api.bangladeshpetassociation.com/api/v1

# Client-side URL used by browser-side fetch calls.
NEXT_PUBLIC_API_URL=https://api.bangladeshpetassociation.com/api/v1

# ─── Media ───────────────────────────────────────────────────────────────────
# Must match MEDIA_PUBLIC_BASE_URL in backend-api .env.
# No trailing slash.
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.bangladeshpetassociation.com

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://admin.bangladeshpetassociation.com

# ─── Frontend URL (used for care-card verification links) ─────────────────────
NEXT_PUBLIC_FRONTEND_URL=https://bangladeshpetassociation.com

# ─── Google Tag Manager (optional for admin panel) ───────────────────────────
NEXT_PUBLIC_GTM_ID=

# ─── Google Analytics 4 (optional) ──────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
